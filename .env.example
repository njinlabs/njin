# Server
PORT=3000

# Database
DB_PATH=rocksdb://mydb
DB_NAMESPACE=general
DB_DATABASE=general

# File storage (used by the default filesystem adapter — src/core/adapters/bun_filesystem.ts)
FILE_DIR=./uploads

# S3 storage (only needed if src/config/adapter.ts uses src/core/adapters/s3.ts instead)
# S3_BUCKET=my-bucket
# S3_REGION=us-east-1
# S3_ACCESS_KEY_ID=
# S3_SECRET_ACCESS_KEY=
# S3_ENDPOINT=https://<account-id>.r2.cloudflarestorage.com

# Image optimization — comma-separated external hosts allowed for GET /img besides same-origin/localhost
IMG_HOSTS=
